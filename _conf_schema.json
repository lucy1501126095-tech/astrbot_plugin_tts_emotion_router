{
  "minimax": {
    "type": "object",
    "description": "MiniMax TTS 配置（中文语音）",
    "items": {
      "key": {
        "type": "string",
        "description": "API Key",
        "default": ""
      },
      "url": {
        "type": "string",
        "description": "API 地址",
        "default": "https://api.minimaxi.com/v1/t2a_v2"
      },
      "model": {
        "type": "string",
        "description": "模型",
        "default": "speech-2.8-hd"
      },
      "voice_id": {
        "type": "string",
        "description": "音色 ID",
        "default": ""
      },
      "speed": {
        "type": "float",
        "description": "语速（0.5~2.0）",
        "default": 1.0
      },
      "emotion": {
        "type": "string",
        "description": "默认情绪",
        "options": ["neutral", "happy", "sad", "angry"],
        "default": "neutral"
      },
      "audio_format": {
        "type": "string",
        "description": "音频格式",
        "options": ["mp3", "wav", "opus"],
        "default": "mp3"
      },
      "sample_rate": {
        "type": "int",
        "description": "采样率",
        "default": 32000
      },
      "vol": {
        "type": "float",
        "description": "音量（0~10）",
        "default": 1.0
      },
      "pitch": {
        "type": "int",
        "description": "音调（-12~12）",
        "default": 0
      }
    }
  },
  "elevenlabs": {
    "type": "object",
    "description": "ElevenLabs TTS 配置（非中文语音）",
    "items": {
      "key": {
        "type": "string",
        "description": "API Key（xi-api-key）",
        "default": ""
      },
      "voice_id": {
        "type": "string",
        "description": "Voice ID",
        "default": ""
      },
      "model_id": {
        "type": "string",
        "description": "模型 ID",
        "options": ["eleven_v3", "eleven_flash_v2_5", "eleven_multilingual_v2"],
        "default": "eleven_v3"
      },
      "url": {
        "type": "string",
        "description": "API 地址",
        "default": "https://api.elevenlabs.io"
      },
      "stability": {
        "type": "float",
        "description": "稳定性（0~1）",
        "default": 0.5
      },
      "similarity_boost": {
        "type": "float",
        "description": "相似度增强（0~1）",
        "default": 0.75
      },
      "style": {
        "type": "float",
        "description": "风格化程度（0~1）",
        "default": 0.0
      },
      "use_speaker_boost": {
        "type": "bool",
        "description": "启用说话人增强",
        "default": true
      },
      "output_format": {
        "type": "string",
        "description": "输出格式",
        "options": ["mp3_44100_128", "mp3_22050_32", "pcm_16000", "pcm_22050", "pcm_24000", "pcm_44100"],
        "default": "mp3_44100_128"
      }
    }
  }
}
